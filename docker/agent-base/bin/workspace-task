#!/bin/sh
# workspace-task — create, list, and update tasks
# Usage:
#   workspace-task create "title" [--description "..."] [--priority high|normal|low] [--assign <memberId>]
#   workspace-task list [--status pending|assigned|in_progress|completed|failed] [--priority high] [--mine]
#   workspace-task update <taskId> --status in_progress
#   workspace-task update <taskId> --status completed
#
# Requires: ROUTER_URL, ROUTER_SERVICE_KEY, AGENT_MEMBER_ID, AGENT_PROJECT_ID

set -e

# ── Preflight: check required env vars ──
missing=""
[ -z "$ROUTER_URL" ] && missing="$missing ROUTER_URL"
[ -z "$ROUTER_SERVICE_KEY" ] && missing="$missing ROUTER_SERVICE_KEY"
[ -z "$AGENT_MEMBER_ID" ] && missing="$missing AGENT_MEMBER_ID"
[ -z "$AGENT_PROJECT_ID" ] && missing="$missing AGENT_PROJECT_ID"
if [ -n "$missing" ]; then
  echo "Error: Missing required env vars:$missing"
  echo "These are set during provisioning. If missing, the machine was provisioned without workspace context."
  exit 1
fi

API="${ROUTER_URL}/v1/agent"
AUTH="Authorization: Bearer ${ROUTER_SERVICE_KEY}"
MEMBER="X-Agent-Member-Id: ${AGENT_MEMBER_ID}"
PROJECT="X-Agent-Project-Id: ${AGENT_PROJECT_ID}"

usage() {
  echo "Usage:"
  echo "  workspace-task create \"title\" [--description \"...\"] [--priority high|normal|low] [--assign <memberId>]"
  echo "  workspace-task list [--status STATUS] [--priority PRIORITY] [--mine] [--limit N]"
  echo "  workspace-task update <taskId> --status STATUS [--priority PRIORITY] [--title \"...\"]"
  exit 1
}

# Helper: run curl and show errors clearly
api_call() {
  METHOD="$1"; shift
  URL="$1"; shift
  TMPFILE=$(mktemp)
  HTTP_CODE=$(curl -s -o "$TMPFILE" -w "%{http_code}" -X "$METHOD" "$URL" \
    -H "$AUTH" -H "$MEMBER" -H "$PROJECT" "$@" 2>&1)
  if [ "$HTTP_CODE" -ge 400 ] 2>/dev/null || [ "$HTTP_CODE" = "000" ]; then
    echo "Error: HTTP $HTTP_CODE from $URL"
    cat "$TMPFILE" 2>/dev/null
    rm -f "$TMPFILE"
    exit 1
  fi
  cat "$TMPFILE"
  rm -f "$TMPFILE"
}

case "${1:-}" in
  create)
    shift
    TITLE=""
    DESC=""
    PRIORITY="normal"
    ASSIGN=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --description) DESC="$2"; shift 2 ;;
        --priority)    PRIORITY="$2"; shift 2 ;;
        --assign)      ASSIGN="$2"; shift 2 ;;
        *)             TITLE="$1"; shift ;;
      esac
    done
    if [ -z "$TITLE" ]; then
      echo "Error: title is required"
      exit 1
    fi
    BODY="{\"title\":\"$(echo "$TITLE" | sed 's/"/\\"/g')\",\"priority\":\"$PRIORITY\""
    if [ -n "$DESC" ]; then
      BODY="$BODY,\"description\":\"$(echo "$DESC" | sed 's/"/\\"/g')\""
    fi
    if [ -n "$ASSIGN" ]; then
      BODY="$BODY,\"assignedTo\":\"$ASSIGN\""
    fi
    BODY="$BODY}"
    api_call POST "${API}/tasks" \
      -H "Content-Type: application/json" \
      -d "$BODY"
    echo
    ;;

  list)
    shift
    QUERY=""
    while [ $# -gt 0 ]; do
      case "$1" in
        --status)   QUERY="${QUERY}&status=$2"; shift 2 ;;
        --priority) QUERY="${QUERY}&priority=$2"; shift 2 ;;
        --mine)     QUERY="${QUERY}&assignee=me"; shift ;;
        --limit)    QUERY="${QUERY}&limit=$2"; shift 2 ;;
        *)          shift ;;
      esac
    done
    QUERY="$(echo "$QUERY" | sed 's/^&//')"
    api_call GET "${API}/tasks?${QUERY}" | \
      node -e "
        const d=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));
        if(d.error){console.log('API Error:',d.error);process.exit(1)}
        (d.tasks||[]).forEach(t=>{
          const pri=t.priority==='high'?'!!':t.priority==='low'?'..':'  ';
          console.log(pri+' ['+t.status+'] '+t.title+' ('+t.id.slice(0,8)+')');
          if(t.description) console.log('   '+t.description.slice(0,120));
        });
        if(!(d.tasks||[]).length) console.log('No tasks found.');
      "
    ;;

  update)
    TASK_ID="$2"
    if [ -z "$TASK_ID" ]; then
      echo "Error: taskId is required"
      exit 1
    fi
    shift 2
    BODY="{\"taskId\":\"$TASK_ID\""
    while [ $# -gt 0 ]; do
      case "$1" in
        --status)      BODY="$BODY,\"status\":\"$2\""; shift 2 ;;
        --priority)    BODY="$BODY,\"priority\":\"$2\""; shift 2 ;;
        --title)       BODY="$BODY,\"title\":\"$(echo "$2" | sed 's/"/\\"/g')\""; shift 2 ;;
        --description) BODY="$BODY,\"description\":\"$(echo "$2" | sed 's/"/\\"/g')\""; shift 2 ;;
        --assign)      BODY="$BODY,\"assignedTo\":\"$2\""; shift 2 ;;
        *)             shift ;;
      esac
    done
    BODY="$BODY}"
    api_call PATCH "${API}/tasks" \
      -H "Content-Type: application/json" \
      -d "$BODY"
    echo
    ;;

  *)
    usage
    ;;
esac
